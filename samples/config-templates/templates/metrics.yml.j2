# Prometheus Metrics Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ environment }}

# Metrics export configuration
metrics:
  enabled: {{ metrics_enabled | lower }}
  port: 9090
  path: {{ metrics_path }}
  
  # Metric collection intervals
  collection:
    interval: {{ '15s' if environment == 'production' else '30s' }}
    timeout: 10s
  
  # Metric categories
  categories:
    # JVM metrics
    jvm:
      enabled: true
      include:
        - memory
        - gc
        - threads
        - classes
        - buffers
    
    # System metrics
    system:
      enabled: true
      include:
        - cpu
        - memory
        - disk
        - network
        - process
    
    # Application metrics
    application:
      enabled: true
      include:
        - http_requests
        - http_response_time
        - database_connections
        - database_queries
        - cache_hits
        - cache_misses
        - active_sessions
    
    # Business metrics
    business:
      enabled: {{ 'true' if environment == 'production' else 'false' }}
      include:
        - user_registrations
        - user_logins
        - transactions
        - api_calls

# Custom metrics
custom_metrics:
  - name: {{ app_name }}_requests_total
    type: counter
    help: Total number of requests
    labels:
      - method
      - endpoint
      - status
  
  - name: {{ app_name }}_request_duration_seconds
    type: histogram
    help: Request duration in seconds
    buckets: [0.001, 0.005, 0.01, 0.05, 0.1, 0.5, 1.0, 5.0]
    labels:
      - method
      - endpoint
  
  - name: {{ app_name }}_database_connection_pool_size
    type: gauge
    help: Current database connection pool size
    labels:
      - pool
      - state
  
  - name: {{ app_name }}_cache_operations_total
    type: counter
    help: Total cache operations
    labels:
      - operation
      - result
  
  - name: {{ app_name }}_active_users
    type: gauge
    help: Number of currently active users

# Alert thresholds
alerts:
  response_time:
    warning: 1.0
    critical: 5.0
  
  error_rate:
    warning: 0.01
    critical: 0.05
  
  memory_usage:
    warning: 80
    critical: 90
  
  cpu_usage:
    warning: 70
    critical: 85

# Prometheus scrape configuration
prometheus:
  scrape_interval: 15s
  scrape_timeout: 10s
  
  # Labels applied to all metrics
  global_labels:
    environment: {{ environment }}
    application: {{ app_name }}
    version: {{ config_version }}
{% if environment == 'production' %}
    datacenter: us-east-1
    cluster: production
{% endif %}
