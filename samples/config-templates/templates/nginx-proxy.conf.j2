# NGINX Reverse Proxy Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Application: {{ app_name }}
# Environment: {{ environment }}

upstream {{ app_name }}_backend {
    least_conn;
    
    # Backend application servers
    server localhost:{{ app_port }} max_fails=3 fail_timeout=30s;
    
    keepalive 32;
}

{% if environment == 'production' %}
# HTTP to HTTPS redirect
server {
    listen 80;
    server_name {{ app_name }}.example.com;
    
    location / {
        return 301 https://$server_name$request_uri;
    }
}
{% endif %}

server {
    {% if environment == 'production' %}
    listen 443 ssl http2;
    server_name {{ app_name }}.example.com;
    
    # SSL Configuration
    ssl_certificate /etc/ssl/certs/{{ app_name }}.crt;
    ssl_certificate_key /etc/ssl/private/{{ app_name }}.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    {% else %}
    listen 80;
    server_name {{ app_name }}.local;
    {% endif %}
    
    # Logging
    access_log /var/log/nginx/{{ app_name }}_access.log;
    error_log /var/log/nginx/{{ app_name }}_error.log warn;
    
    # Client settings
    client_max_body_size {{ '10M' if environment == 'production' else '5M' }};
    client_body_timeout 60s;
    client_header_timeout 60s;
    
    # Compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain text/css text/xml text/javascript application/json application/javascript application/xml+rss application/rss+xml;
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    {% if environment == 'production' %}
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
    {% endif %}
    
    # Health check endpoint (no authentication)
    location {{ health_check_path }} {
        proxy_pass http://{{ app_name }}_backend{{ health_check_path }};
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        access_log off;
    }
    
    {% if metrics_enabled %}
    # Metrics endpoint (restricted access)
    location {{ metrics_path }} {
        {% if environment == 'production' %}
        allow 10.0.0.0/8;
        deny all;
        {% endif %}
        
        proxy_pass http://{{ app_name }}_backend{{ metrics_path }};
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }
    {% endif %}
    
    # Static files
    location /static/ {
        alias /var/www/{{ app_name }}/static/;
        expires 7d;
        add_header Cache-Control "public, immutable";
    }
    
    # Application proxy
    location / {
        proxy_pass http://{{ app_name }}_backend;
        proxy_http_version 1.1;
        
        # Headers
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port $server_port;
        
        # WebSocket support
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        
        # Timeouts
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
        
        # Buffering
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;
        
        # Connection keep-alive
        proxy_set_header Connection "";
    }
    
    # Error pages
    error_page 500 502 503 504 /50x.html;
    location = /50x.html {
        root /usr/share/nginx/html;
    }
    
    {% if enable_debug %}
    # Debug endpoint (development only)
    location /debug/ {
        proxy_pass http://{{ app_name }}_backend/debug/;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
    }
    {% endif %}
}
