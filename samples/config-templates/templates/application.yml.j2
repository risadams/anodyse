# Application Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ environment }}
# Version: {{ config_version }}

application:
  name: {{ app_name }}
  version: {{ config_version }}
  environment: {{ environment }}
  
server:
  port: {{ app_port }}
  address: 0.0.0.0
  shutdown: graceful
  compression:
    enabled: true
    min-response-size: 1024
  
  # Session configuration
  servlet:
    session:
      timeout: {{ session_timeout }}s
      cookie:
        http-only: true
        secure: {{ 'true' if environment == 'production' else 'false' }}
        same-site: strict

logging:
  config: {{ config_base_path }}/log4j2.xml
  level:
    root: {{ log_level }}
    com.example.myapp: {{ log_level }}
    org.springframework: WARN
    org.hibernate: {{ 'DEBUG' if enable_debug else 'WARN' }}

database:
  host: {{ db_host }}
  port: {{ db_port }}
  name: {{ db_name }}
  username: {{ db_username }}
  pool:
    minimum-idle: {{ db_pool_min }}
    maximum-pool-size: {{ db_pool_max }}
    connection-timeout: 30000
    idle-timeout: 600000
    max-lifetime: 1800000

cache:
  type: redis
  redis:
    host: {{ redis_host }}
    port: {{ redis_port }}
    database: {{ redis_db }}
    timeout: 2000
    ttl: {{ cache_ttl }}

security:
  jwt:
    secret: "${JWT_SECRET}"
    expiration: {{ jwt_expiration }}
  cors:
    allowed-origins:
{% for origin in cors_allowed_origins %}
      - {{ origin }}
{% endfor %}
    allowed-methods:
      - GET
      - POST
      - PUT
      - DELETE
      - OPTIONS
    allowed-headers: "*"
    allow-credentials: true

features:
  api-v2-enabled: {{ feature_flags.enable_api_v2 | lower }}
  analytics-enabled: {{ feature_flags.enable_analytics | lower }}
  experimental-enabled: {{ feature_flags.enable_experimental | lower }}
  rate-limiting-enabled: {{ feature_flags.enable_rate_limiting | lower }}

{% if metrics_enabled %}
management:
  endpoints:
    web:
      base-path: {{ metrics_path }}
      exposure:
        include:
          - health
          - metrics
          - prometheus
          - info
  endpoint:
    health:
      show-details: {{ 'always' if enable_debug else 'when-authorized' }}
    metrics:
      enabled: true
  metrics:
    export:
      prometheus:
        enabled: true
{% endif %}

email:
  smtp:
    host: {{ smtp_host }}
    port: {{ smtp_port }}
    username: "${SMTP_USERNAME}"
    password: "${SMTP_PASSWORD}"
    from: {{ smtp_from }}
    properties:
      mail.smtp.auth: true
      mail.smtp.starttls.enable: true
      mail.smtp.starttls.required: true

{% if environment == 'development' %}
# Development-specific settings
spring:
  devtools:
    restart:
      enabled: true
    livereload:
      enabled: true
{% endif %}

{% if environment == 'production' %}
# Production-specific settings
server:
  error:
    include-message: never
    include-stacktrace: never
    include-exception: false
{% endif %}
