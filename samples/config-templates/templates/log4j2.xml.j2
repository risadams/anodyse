<?xml version="1.0" encoding="UTF-8"?>
<!-- 
  Log4j2 Configuration
  Generated by Ansible on {{ ansible_date_time.iso8601 }}
  Environment: {{ environment }}
-->
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <Property name="LOG_PATTERN">%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</Property>
        <Property name="LOG_PATH">/var/log/{{ app_name }}</Property>
        <Property name="APP_NAME">{{ app_name }}</Property>
    </Properties>

    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <ThresholdFilter level="{{ log_level }}" onMatch="ACCEPT" onMismatch="DENY"/>
        </Console>

        <!-- Application Log File -->
        <RollingFile name="ApplicationLog" 
                     fileName="${LOG_PATH}/${APP_NAME}.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="{{ '100MB' if environment == 'production' else '50MB' }}"/>
            </Policies>
            <DefaultRolloverStrategy max="{{ '30' if environment == 'production' else '7' }}"/>
        </RollingFile>

        <!-- Error Log File -->
        <RollingFile name="ErrorLog" 
                     fileName="${LOG_PATH}/${APP_NAME}-error.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="${LOG_PATTERN}"/>
            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="50MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

        <!-- Performance Log (production only) -->
        {% if environment == 'production' %}
        <RollingFile name="PerformanceLog" 
                     fileName="${LOG_PATH}/${APP_NAME}-performance.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-performance-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS}|%msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
        {% endif %}

        <!-- Async Wrapper for better performance -->
        <Async name="AsyncApplicationLog" includeLocation="true">
            <AppenderRef ref="ApplicationLog"/>
        </Async>

        {% if enable_debug %}
        <!-- Debug SQL Log (development/debug only) -->
        <RollingFile name="SqlLog" 
                     fileName="${LOG_PATH}/${APP_NAME}-sql.log"
                     filePattern="${LOG_PATH}/${APP_NAME}-sql-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS}|%msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
            </Policies>
            <DefaultRolloverStrategy max="3"/>
        </RollingFile>
        {% endif %}
    </Appenders>

    <Loggers>
        <!-- Application Logger -->
        <Logger name="com.example.myapp" level="{{ log_level }}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncApplicationLog"/>
            <AppenderRef ref="ErrorLog"/>
        </Logger>

        <!-- Spring Framework -->
        <Logger name="org.springframework" level="{{ 'DEBUG' if enable_debug else 'WARN' }}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncApplicationLog"/>
        </Logger>

        <!-- Hibernate/JPA -->
        <Logger name="org.hibernate" level="{{ 'DEBUG' if enable_debug else 'WARN' }}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncApplicationLog"/>
        </Logger>

        {% if enable_debug %}
        <!-- SQL Logging (debug mode) -->
        <Logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <AppenderRef ref="SqlLog"/>
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="org.hibernate.type.descriptor.sql.BasicBinder" level="TRACE" additivity="false">
            <AppenderRef ref="SqlLog"/>
        </Logger>
        {% endif %}

        <!-- Security -->
        <Logger name="org.springframework.security" level="{{ 'DEBUG' if enable_debug else 'INFO' }}" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncApplicationLog"/>
        </Logger>

        <!-- Performance Logger (production) -->
        {% if environment == 'production' %}
        <Logger name="com.example.myapp.performance" level="INFO" additivity="false">
            <AppenderRef ref="PerformanceLog"/>
        </Logger>
        {% endif %}

        <!-- Root Logger -->
        <Root level="{{ log_level }}">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="AsyncApplicationLog"/>
            <AppenderRef ref="ErrorLog"/>
        </Root>
    </Loggers>
</Configuration>
