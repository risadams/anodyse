# Database Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ environment }}

[database]
# Connection settings
host = {{ db_host }}
port = {{ db_port }}
database = {{ db_name }}
username = {{ db_username }}
password = ${DB_PASSWORD}

# SSL/TLS settings
{% if environment == 'production' %}
sslmode = require
sslrootcert = /etc/ssl/certs/ca-bundle.crt
{% else %}
sslmode = prefer
{% endif %}

# Connection pool settings
[pool]
min_size = {{ db_pool_min }}
max_size = {{ db_pool_max }}
connection_timeout = 30
idle_timeout = 600
max_lifetime = 1800
validation_timeout = 5

# Pool behavior
pool_pre_ping = true
pool_recycle = 3600
pool_use_lifo = true

# Statement settings
[statements]
statement_timeout = 30000
idle_in_transaction_session_timeout = 60000

# Logging
[logging]
log_min_duration_statement = {{ '1000' if environment == 'production' else '0' }}
log_connections = {{ 'true' if enable_debug else 'false' }}
log_disconnections = {{ 'true' if enable_debug else 'false' }}
log_statement = {{ 'all' if enable_debug else 'none' }}

# Performance tuning
[performance]
shared_buffers = 256MB
effective_cache_size = 1GB
maintenance_work_mem = 64MB
checkpoint_completion_target = 0.9
wal_buffers = 16MB
default_statistics_target = 100
random_page_cost = 1.1
effective_io_concurrency = 200
work_mem = {{ '16MB' if environment == 'production' else '4MB' }}
min_wal_size = 1GB
max_wal_size = 4GB

# Replication (production only)
{% if environment == 'production' %}
[replication]
max_wal_senders = 10
wal_keep_size = 1GB
hot_standby = on
hot_standby_feedback = on
{% endif %}
