# Security Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ environment }}

# Session Management
session.timeout={{ session_timeout }}
session.cookie.name=JSESSIONID
session.cookie.httpOnly=true
session.cookie.secure={{ 'true' if environment == 'production' else 'false' }}
session.cookie.sameSite=Strict
session.tracking.mode=COOKIE
session.concurrent.max={{ '1' if environment == 'production' else '5' }}

# JWT Configuration
jwt.secret=${JWT_SECRET}
jwt.expiration={{ jwt_expiration }}
jwt.issuer={{ app_name }}
jwt.refresh.enabled={{ 'true' if environment == 'production' else 'false' }}
jwt.refresh.expiration={{ jwt_expiration * 24 }}

# CORS Configuration
cors.enabled=true
cors.allowedOrigins={{ ','.join(cors_allowed_origins) }}
cors.allowedMethods=GET,POST,PUT,DELETE,OPTIONS
cors.allowedHeaders=*
cors.allowCredentials=true
cors.maxAge=3600

# Authentication
auth.login.maxAttempts={{ '3' if environment == 'production' else '5' }}
auth.login.lockoutDuration=900
auth.password.minLength={{ '12' if environment == 'production' else '8' }}
auth.password.requireUppercase=true
auth.password.requireLowercase=true
auth.password.requireDigit=true
auth.password.requireSpecial={{ 'true' if environment == 'production' else 'false' }}
auth.password.expiryDays={{ '90' if environment == 'production' else '365' }}

# Multi-Factor Authentication
mfa.enabled={{ 'true' if environment == 'production' else 'false' }}
mfa.issuer={{ app_name }}
mfa.requiredForAdmin={{ 'true' if environment == 'production' else 'false' }}

# SSL/TLS
ssl.enabled={{ 'true' if environment == 'production' else 'false' }}
ssl.protocol=TLSv1.3
ssl.ciphers=TLS_AES_128_GCM_SHA256:TLS_AES_256_GCM_SHA384
ssl.clientAuth=none

# Content Security Policy
csp.enabled={{ 'true' if environment == 'production' else 'false' }}
csp.policy=default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'

# Security Headers
security.headers.xss.enabled=true
security.headers.xss.block=true
security.headers.contentType.enabled=true
security.headers.frameOptions=SAMEORIGIN
security.headers.hsts.enabled={{ 'true' if environment == 'production' else 'false' }}
security.headers.hsts.maxAge=31536000
security.headers.hsts.includeSubDomains=true

# Rate Limiting
ratelimit.enabled={{ feature_flags.enable_rate_limiting | lower }}
ratelimit.requests={{ '100' if feature_flags.enable_rate_limiting else '1000' }}
ratelimit.window=60
ratelimit.burst={{ '50' if feature_flags.enable_rate_limiting else '500' }}

# Audit Logging
audit.enabled={{ 'true' if environment == 'production' else 'false' }}
audit.logLevel=INFO
audit.includeRequestBody=false
audit.includeResponseBody=false
