# Environment Configuration
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# Environment: {{ environment }}
# DO NOT COMMIT THIS FILE TO VERSION CONTROL

# Application
APP_NAME={{ app_name }}
APP_VERSION={{ config_version }}
APP_ENV={{ environment }}
APP_DEBUG={{ enable_debug | lower }}
APP_PORT={{ app_port }}
APP_BASE_URL={{ 'https://' + app_name + '.example.com' if environment == 'production' else 'http://localhost:' + app_port|string }}

# Database
DB_HOST={{ db_host }}
DB_PORT={{ db_port }}
DB_NAME={{ db_name }}
DB_USERNAME={{ db_username }}
DB_PASSWORD=${DB_PASSWORD}
DB_POOL_MIN={{ db_pool_min }}
DB_POOL_MAX={{ db_pool_max }}

# Cache
REDIS_HOST={{ redis_host }}
REDIS_PORT={{ redis_port }}
REDIS_DB={{ redis_db }}
REDIS_PASSWORD=${REDIS_PASSWORD}
CACHE_TTL={{ cache_ttl }}

# Security
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRATION={{ jwt_expiration }}
SESSION_TIMEOUT={{ session_timeout }}
SESSION_SECRET=${SESSION_SECRET}

# Email
SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port }}
SMTP_USERNAME=${SMTP_USERNAME}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM={{ smtp_from }}

# Logging
LOG_LEVEL={{ log_level }}
LOG_PATH=/var/log/{{ app_name }}

# Features
FEATURE_API_V2={{ feature_flags.enable_api_v2 | upper }}
FEATURE_ANALYTICS={{ feature_flags.enable_analytics | upper }}
FEATURE_EXPERIMENTAL={{ feature_flags.enable_experimental | upper }}
FEATURE_RATE_LIMITING={{ feature_flags.enable_rate_limiting | upper }}

# Monitoring
{% if metrics_enabled %}
METRICS_ENABLED=TRUE
METRICS_PORT=9090
PROMETHEUS_ENABLED=TRUE
{% else %}
METRICS_ENABLED=FALSE
{% endif %}

# External Services
{% if environment == 'production' %}
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_ACCESS_KEY_ID}
AWS_SECRET_ACCESS_KEY=${AWS_SECRET_ACCESS_KEY}
S3_BUCKET={{ app_name }}-prod-assets
{% endif %}

# Performance
WORKER_THREADS={{ '8' if environment == 'production' else '2' }}
CONNECTION_POOL_SIZE={{ db_pool_max }}
REQUEST_TIMEOUT=30000
